# Environment
.env

# Configuration
config/database.local.php

# Installation lock
app/storage/installed.lock

# Migration lock files (environment-specific)
app/storage/.migrations_applied
app/storage/.migrations_applied_v2
app/storage/.migrations_applied_v3

# Maintenance mode flag (created during deployments)
app/storage/.maintenance

# Update lock
.update_lock

# IDE / project files
nbproject/
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# OS files
Thumbs.db
.DS_Store
Desktop.ini

# Logs
*.log
app/storage/logs/*
!app/storage/logs/.gitkeep

# Uploads
app/storage/uploads/*
!app/storage/uploads/.gitkeep

# Dependencies
# PHPMailer source files are included in vendor/phpmailer/
